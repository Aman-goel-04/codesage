{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",

    "rootDir": "./src",
    "outDir": "dist",

    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "src/generated"]
}